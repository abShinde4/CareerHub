# ============================================================
# Place this file at: backend/.env
# Copy: cp backend/.env.example backend/.env
# Then replace placeholder values with your MongoDB Atlas credentials
# ============================================================

# MongoDB Atlas connection string
# Atlas -> Database -> Connect -> Drivers -> Node.js -> copy URI
# Format:
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/careerhub?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/careerhub?retryWrites=true&w=majority

JWT_SECRET=your_super_secret_jwt_key_change_in_production
PORT=5000

ADMIN_NAME=Admin
ADMIN_EMAIL=admin@careerhub.com
ADMIN_PASSWORD=admin123
